### VITALS ###
NODE_PORT=2222
SECRET_KEY=
# 如果平台限制环境变量长度，可拆分为多个分片：
# SECRET_KEY_1=<前半段>
# SECRET_KEY_2=<后半段>
# SECRET_KEY_3=<更多分片（如需要）>

### Internal (local) ports ###
INTERNAL_REST_PORT=61001

### Runtime ###
REQUIRE_SECRET_KEY=true
NODE_TLS_CLIENT_AUTH=mtls
XRAY_LOCATION_ASSET=/opt/rw-node/share/xray

### HTTP Front (Caddy Layer 4, optional) ###
# HTTP_FRONT_ENABLED=false
# HTTP_FRONT_PORT=3000
# XHTTP_UPSTREAM_PORT=8080
# WS_UPSTREAM_PORT=8880
# CADDY_INDEX_PAGE=mikutap
# REALITY_SPLIT_ENABLED=true
# REALITY_SPLIT_INTERVAL=15

### Memory tuning (Go runtime) ###
# GOGC=50
# GOMEMLIMIT=128MiB
